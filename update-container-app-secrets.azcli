#!/bin/bash

# This script updates the secrets for the Cortana Agent Kit Container App
# Run this after the initial deployment to set actual secret values

RESOURCE_GROUP="cortana-agent-kit-rg"
CONTAINER_APP_NAME="cortana-agent-kit"

echo "Updating secrets for Container App '$CONTAINER_APP_NAME'..."
echo "You will be prompted to enter the actual values for each secret."
echo ""

# Function to read secret value securely
read_secret() {
    local secret_name=$1
    local prompt=$2
    echo -n "$prompt: "
    read -s secret_value
    echo ""
    
    if [ -n "$secret_value" ]; then
        az containerapp secret set \
            --name $CONTAINER_APP_NAME \
            --resource-group $RESOURCE_GROUP \
            --secrets "${secret_name}=${secret_value}"
        echo "✅ Updated $secret_name"
    else
        echo "⚠️  Skipped $secret_name (empty value)"
    fi
    echo ""
}

# Read and update each secret
read_secret "azure-openai-api-key-o4-mini" "Enter Azure OpenAI API Key for O4-Mini model"
read_secret "azure-openai-api-key-deepseek-r1" "Enter Azure OpenAI API Key for DeepSeek-R1 model"
read_secret "email-host" "Enter Email SMTP Host (e.g., smtp.gmail.com)"
read_secret "email-user" "Enter Email Username"
read_secret "email-pass" "Enter Email Password"
read_secret "email-from" "Enter Email From Address"
read_secret "email-to" "Enter Email To Address"
read_secret "alpha-vantage-api-key" "Enter Alpha Vantage API Key"

echo "🎉 Secrets update completed!"
echo ""
echo "To restart the container app with new secrets:"
echo "az containerapp revision restart --name $CONTAINER_APP_NAME --resource-group $RESOURCE_GROUP"
echo ""
echo "To check the deployment status:"
echo "az containerapp show --name $CONTAINER_APP_NAME --resource-group $RESOURCE_GROUP --query properties.latestReadyRevisionName"