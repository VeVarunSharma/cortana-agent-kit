# Azure AI Project
AZURE_AI_PROJECT_ENDPOINT_STRING=your_project_endpoint_string
AZURE_OPENAI_API_DEPLOYMENT_NAME=your_azure_openai_deployment_name
AZURE_OPENAI_API_VERSION=2024-05-01

# Email Service (Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=user@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM="Cortana Agent Service" <user@example.com>
EMAIL_TO=recipient@example.com
